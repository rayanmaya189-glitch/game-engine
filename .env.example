# ===========================================
# Game Engine Casino - Environment Variables
# Copy this file to .env and fill in the values
# ===========================================

# ===========================================
# Application Settings
# ===========================================

# Application environment
NODE_ENV=development
APP_ENV=development
LOG_LEVEL=debug

# Service name (for logging and metrics)
SERVICE_NAME=
SERVICE_VERSION=1.0.0

# ===========================================
# Server Configuration
# ===========================================

# Server host and port
HOST=0.0.0.0
HTTP_PORT=8080
GRPC_PORT=8081

# ===========================================
# Database Configuration
# ===========================================

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=game_engine
DB_SSL_MODE=disable
DB_MAX_CONNECTIONS=100
DB_MAX_IDLE_CONNECTIONS=10
DB_CONN_MAX_LIFETIME=300000
DB_CONN_MAX_IDLE_TIME=60000

# TimescaleDB (for time-series data)
TIMESCALEDB_HOST=localhost
TIMESCALEDB_PORT=5433
TIMESCALEDB_USER=postgres
TIMESCALEDB_PASSWORD=postgres
TIMESCALEDB_NAME=timeseries

# ===========================================
# Redis Configuration
# ===========================================

REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_MAX_RETRIES=3
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONNS=10

# ===========================================
# NATS Configuration
# ===========================================

NATS_HOST=localhost
NATS_PORT=4222
NATS_USER=
NATS_PASSWORD=
NATS_CLUSTER=game_engine
NATS_STREAM=GAME_EVENTS

# ===========================================
# JWT & Authentication
# ===========================================

# JWT settings
JWT_SECRET=${JWT_SECRET:-change-me-in-production}
JWT_PUBLIC_KEY=
JWT_PRIVATE_KEY=
JWT_ALGORITHM=RS256
JWT_EXPIRATION=24h
JWT_REFRESH_EXPIRATION=168h

# Session settings
SESSION_SECRET=your-session-secret-here-change-in-production
SESSION_TIMEOUT=30m
SESSION_COOKIE_NAME=game_session

# ===========================================
# Security
# ===========================================

# Encryption keys
ENCRYPTION_KEY=your-32-byte-encryption-key-here
HASH_SALT_ROUNDS=12

# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Origin,Content-Type,Accept,Authorization
CORS_EXPOSE_HEADERS=
CORS_ALLOW_CREDENTIALS=true
CORS_MAX_AGE=86400

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=1m
RATE_LIMIT_BURST=10

# ===========================================
# External Services
# ===========================================

# Kratos (Authentication)
KRATOS_PUBLIC_URL=http://localhost:4433
KRATOS_ADMIN_URL=http://localhost:4434
KRATOS_DSN=postgres://postgres:postgres@localhost:5432/kratos?sslmode=disable
KRATOS_LOG_LEVEL=debug

# ===========================================
# Feature Flags
# ===========================================

# Feature flags
FEATURE_REGISTRATION_ENABLED=true
FEATURE_SOCIAL_LOGIN=false
FEATURE_2FA_ENABLED=false
FEATURE_WITHDRAWAL_ENABLED=true
FEATURE_DEPOSIT_ENABLED=true

# Game settings
GAME_MIN_BET=1.0
GAME_MAX_BET=100000.0
GAME_MAX_PLAYERS_PER_TABLE=6

# Wallet settings
WALLET_MIN_DEPOSIT=10.0
WALLET_MAX_DEPOSIT=1000000.0
WALLET_MIN_WITHDRAWAL=10.0
WALLET_MAX_WITHDRAWAL=100000.0
WALLET_WITHDRAWAL_FEE_PERCENT=0

# ===========================================
# Observability
# ===========================================

# Logging
LOG_FORMAT=json
LOG_OUTPUT=stdout

# Tracing (Jaeger)
JAEGER_ENABLED=true
JAEGER_SERVICE_NAME=
JAEGER_AGENT_HOST=localhost
JAEGER_AGENT_PORT=6831
JAEGER_SAMPLER_TYPE=const
JAEGER_SAMPLER_PARAM=1
JAEGER_REPORTER_LOG_SPANS=false
JAEGER_REPORTER_FLUSH_INTERVAL=1000

# Metrics (Prometheus)
PROMETHEUS_ENABLED=true
PROMETHEUS_ENABLED_RUNTIME=true

# ===========================================
# Admin Services
# ===========================================

# pgAdmin
PGADMIN_EMAIL=admin@game_engine.local
PGADMIN_PASSWORD=admin

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# ===========================================
# Development Specific
# ===========================================

# Development settings
DEV_MODE=true
DEV_DB_DROP_AND_CREATE=false
DEV_REDIS_FLUSH=false
DEV_NATS_STREAM_RESET=false

# ===========================================
# Python Compliance Services
# ===========================================

# AML Service
AML_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/aml_db
AML_PORT=9014
AML_STRUCTURING_THRESHOLD=10000
AML_STRUCTURING_COUNT=3
AML_RAPID_WITHDRAW_RATIO=0.8
AML_LARGE_TRANSACTION_THRESHOLD=10000
AML_VELOCITY_THRESHOLD=10
AML_WEIGHT_VELOCITY=0.3
AML_WEIGHT_AVG_AMOUNT=0.25
AML_WEIGHT_WAGERING_RATIO=0.2
AML_WEIGHT_PAYMENT_DIVERSITY=0.15
AML_WEIGHT_GEO_CONSISTENCY=0.1

# Fraud Service
FRAUD_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fraud_db
FRAUD_PORT=9015

# Risk Service
RISK_PORT=9016
AML_SERVICE_URL=http://localhost:9014
FRAUD_SERVICE_URL=http://localhost:9015
RISK_WEIGHT_VELOCITY=0.25
RISK_WEIGHT_AMOUNT=0.20
RISK_WEIGHT_DIVERSITY=0.15
RISK_WEIGHT_WAGERING=0.20
RISK_WEIGHT_GEO=0.20
RISK_DEPOSIT_LIMIT_LOW=50000
RISK_DEPOSIT_LIMIT_MEDIUM=10000
RISK_DEPOSIT_LIMIT_HIGH=1000
RISK_DEPOSIT_LIMIT_CRITICAL=0
RISK_WITHDRAWAL_LIMIT_LOW=50000
RISK_WITHDRAWAL_LIMIT_MEDIUM=5000
RISK_WITHDRAWAL_LIMIT_HIGH=500
RISK_WITHDRAWAL_LIMIT_CRITICAL=0
RISK_BASE_DEPOSIT_LIMIT=100000
RISK_BASE_WITHDRAWAL_LIMIT=50000

# KYC Service
KYC_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/kyc_db
KYC_REDIS_URL=redis://localhost:6379/0
KYC_PORT=9031

# ===========================================
# Betting Service
# ===========================================

BET_MIN_AMOUNT=1
BET_MAX_AMOUNT=100000
BET_MAX_PAYOUT=1000000
BET_MAX_ODDS=1000
BETTING_DATABASE_URL=postgres://postgres:postgres@localhost:5432/betting_db

# ===========================================
# Payment Service
# ===========================================

WALLET_GRPC_HOST=localhost
WALLET_GRPC_PORT=4438
PAYMENT_EXCHANGE_API_URL=
STRIPE_API_KEY=${STRIPE_API_KEY}
STRIPE_WEBHOOK_SECRET=${STRIPE_WEBHOOK_SECRET}

# ===========================================
# Database Passwords (per service)
# ===========================================

DATABASE_PASSWORD=postgres

# Mock services (for testing)
MOCK_PAYMENT_ENABLED=false
MOCK_KYC_ENABLED=false
